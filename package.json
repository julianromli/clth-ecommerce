{
  "name": "CLTH",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "@trpc/server": "^11.16.0",
      "@trpc/client": "^11.16.0",
      "better-auth": "1.6.11",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "vp run -r dev",
    "build": "vp run -r build",
    "check-types": "vp run -r check-types",
    "check": "vp check && vp run -r check-types",
    "lint": "vp lint",
    "format": "vp fmt",
    "staged": "vp staged",
    "hooks:setup": "vp config",
    "dev:web": "vp run --filter web dev",
    "db:push": "vp run --filter @CLTH/db db:push",
    "db:studio": "vp run --filter @CLTH/db db:studio",
    "db:generate": "vp run --filter @CLTH/db db:generate",
    "db:migrate": "vp run --filter @CLTH/db db:migrate"
  },
  "dependencies": {
    "@CLTH/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@CLTH/config": "workspace:*",
    "@types/node": "catalog:",
    "rolldown": "1.1.0",
    "typescript": "catalog:",
    "vite-plus": "0.1.24"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.24",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.24"
  },
  "packageManager": "bun@1.3.11"
}
